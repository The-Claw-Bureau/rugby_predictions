    "'home_team_pre_delta_mean_last_10',\n",
    "'home_team_pre_delta_stdev_last_10',\n",
    "'home_upper_band_2std_last_10',\n",
    "'home_lower_band_2std_last_10',\n",
    "'home_upper_band_1_5std_last_10',\n",
