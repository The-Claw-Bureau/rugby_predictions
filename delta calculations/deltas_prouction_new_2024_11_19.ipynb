    "\n",
    "    cols_to_update = [\n",
    "    'event_id',\n",
    "        'home_attack_pre',\n",
    "        'home_defence_pre',\n",
    "        'home_home_attack_pre',\n",
    "        'home_home_defence_pre',\n",
