    "            datetime_obj =  datetime.datetime.strftime(datetime_obj, '%Y-%m-%d %H:%M:%S')\n",
    "        elif str(datetime_obj)[4]=='/':\n",
    "            datetime_obj = (datetime.datetime.strptime(str(datetime_obj), '%Y/%m/%d %H:%M:%S')) \n",
    "            datetime_obj =  datetime.datetime.strftime(datetime_obj, '%Y-%m-%d %H:%M:%S')\n",
    "        else:\n",
    "            datetime_obj =  'NULL'\n",
    "        \n",
    "    else:\n",
    "        datetime_obj =  'NULL'\n",
    "        \n",
    "\n",
    "    \n",
    "    return datetime_obj\n",
    "    "
   ]
