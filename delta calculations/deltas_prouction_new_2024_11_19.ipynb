    "def fixtures_to_remove(vec):\n",
    "    \n",
    "    to_remove = False\n",
    "    \n",
    "    home_score = vec[0]\n",
    "    away_score = vec[1]\n",
    "    fix_date = vec[2].replace(tzinfo=None)\n",
