    "    events.loc[:, 'error'] = events.loc[:, pre_delta_diff_adjusted] - events.loc[:, delta_column_to_calcuate]\n",
    "\n",
    "    \n",
    "    event_error = events['error'].median()\n",
    "    \n",
    "    return event_error\n",
    "    "
